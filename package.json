{
  "name": "nhitw_preop_checker_2",
  "version": "1.0.0",
  "description": "這是一個專為台灣醫療專業人員打造的 Chrome 擴充功能。能夠在「健保雲端藥歷系統」中，自動掃描並過濾近三個月的術前高風險藥物（如：抗凝血劑、SGLT2 抑制劑、ACEi/ARB 等），並提供**一鍵產出「去識別化」精美術前評估單**的功能。",
  "main": "content.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"src/**/*.{js,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanchen0902/NHITW_preop_checker_2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",

  "bugs": {
    "url": "https://github.com/yanchen0902/NHITW_preop_checker_2/issues"
  },
  "homepage": "https://github.com/yanchen0902/NHITW_preop_checker_2#readme",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
